{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "dotto-figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "dotto-notion": {
      "url": "https://mcp.notion.com/mcp",
      "type": "http"
    },
    "firebase-mcp-server": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "mcp"]
    }
  }
}
